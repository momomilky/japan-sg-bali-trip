<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>東京・星洲・峇里 島嶼漫遊 2026</title>
  
  <!-- Tailwind CSS CDN -->
  <script src="https://cdn.tailwindcss.com"></script>
  <!-- 設定 Tailwind 自訂莫蘭蒂主題色系 -->
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            'theme-bg': '#F5F3F0',         /* 燕麥暖白背景 */
            'theme-card': '#FFFFFF',       /* 卡片底色 */
            'theme-primary': '#C59B9B',    /* 乾燥玫瑰粉 (主要視覺、選中狀態、懸浮按鈕) */
            'theme-secondary': '#E2C2B9',  /* 柔裸粉 (次要視覺、懸浮按鈕) */
            'theme-accent': '#93A2AD',     /* 莫蘭蒂灰藍 (焦點標示與地圖導航按鈕) */
            'theme-dark': '#4A5568',       /* 石墨灰藍文字 */
            'theme-muted': '#93A2AD',      /* 淺灰藍色文字 */
            'theme-light-pink': '#F9F4F4', /* 淡乾燥玫瑰粉背景色塊 */
            'theme-light-blue': '#EBF0F3'  /* 霧藍微灰背景色塊 */
          }
        }
      }
    }
  </script>
  <!-- Vue 3 CDN -->
  <script src="https://unpkg.com/vue@3/dist/vue.global.js"></script>
  <!-- Lucide Icons CDN -->
  <script src="https://unpkg.com/lucide@latest"></script>
  <!-- SortableJS -->
  <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>
  
  <style>
    .no-scrollbar::-webkit-scrollbar { display: none; }
    .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
    body {
      background-color: #F5F3F0; /* 燕麥暖白 */
      color: #4A5568; /* 石墨灰藍 */
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
      -webkit-tap-highlight-color: transparent;
    }
    .app-container {
      max-width: 480px;
      margin: 0 auto;
      min-height: 100vh;
      background-color: #F5F3F0; /* 燕麥暖白 */
      box-shadow: 0 0 20px rgba(197, 155, 155, 0.15);
      position: relative;
      padding-bottom: 90px;
    }
  </style>
</head>
<body>

<div id="app" class="app-container">

  <!-- 頂部 Header -->
  <div class="bg-white px-5 pt-6 pb-4 border-b border-[#EBF0F3] flex items-center justify-between sticky top-0 z-20 shadow-sm">
    <div>
      <p class="text-[10px] tracking-widest uppercase text-theme-primary font-bold">Trip 2026</p>
      <h1 class="text-xl font-bold text-theme-dark tracking-wide">東京・新加坡・峇里</h1>
    </div>

    <!-- 頂部頁籤導覽 -->
    <div class="flex bg-theme-light-blue rounded-full p-1 border border-[#EBF0F3]">
      <button @click="switchTab('itinerary')" :class="{'bg-theme-primary text-white shadow-sm': currentTab === 'itinerary', 'text-theme-dark': currentTab !== 'itinerary'}" class="p-2 rounded-full transition-all">
        <i data-lucide="map-pin" class="w-4 h-4 block"></i>
      </button>
      <button @click="switchTab('todolist')" :class="{'bg-theme-primary text-white shadow-sm': currentTab === 'todolist', 'text-theme-dark': currentTab !== 'todolist'}" class="p-2 rounded-full transition-all">
        <i data-lucide="check-square" class="w-4 h-4 block"></i>
      </button>
      <button @click="switchTab('info')" :class="{'bg-theme-primary text-white shadow-sm': currentTab === 'info', 'text-theme-dark': currentTab !== 'info'}" class="p-2 rounded-full transition-all">
        <i data-lucide="info" class="w-4 h-4 block"></i>
      </button>
      <button @click="switchTab('shopping')" :class="{'bg-theme-primary text-white shadow-sm': currentTab === 'shopping', 'text-theme-dark': currentTab !== 'shopping'}" class="p-2 rounded-full transition-all">
        <i data-lucide="shopping-basket" class="w-4 h-4 block"></i>
      </button>
      <button @click="switchTab('expenses')" :class="{'bg-theme-primary text-white shadow-sm': currentTab === 'expenses', 'text-theme-dark': currentTab !== 'expenses'}" class="p-2 rounded-full transition-all">
        <i data-lucide="coins" class="w-4 h-4 block"></i>
      </button>
    </div>
  </div>

  <!-- 1. 每日行程頁面 -->
  <div v-show="currentTab === 'itinerary'" class="px-4 pt-4">
    
    <!-- 日期選單 -->
    <div class="flex overflow-x-auto space-x-2 pb-3 no-scrollbar">
      <button 
        v-for="date in dates" 
        :key="date.full"
        @click="selectedDate = date.full"
        :class="{'bg-gradient-to-br from-theme-primary to-theme-secondary text-white shadow-md': selectedDate === date.full, 'bg-white text-theme-dark border border-[#EBF0F3]': selectedDate !== date.full}"
        class="flex-shrink-0 w-14 h-16 rounded-2xl flex flex-col items-center justify-center transition-all duration-200">
        <span class="text-xs font-semibold uppercase">{{ date.day }}</span>
        <span class="text-lg font-bold mt-0.5">{{ date.num }}</span>
      </button>
    </div>

    <!-- 天氣資訊 -->
    <div class="bg-white rounded-2xl p-3 my-1 flex items-center justify-between text-theme-dark shadow-sm border border-[#EBF0F3] mb-4">
      <div class="flex items-center space-x-3">
        <i :data-lucide="currentWeather.icon" class="w-7 h-7 text-theme-primary block"></i>
        <div>
          <p class="text-xs text-theme-muted">{{ currentCity }} 天氣</p>
          <p class="text-sm font-medium">{{ currentWeather.temp }}°C <span class="text-xs text-theme-muted">(體感 {{ currentWeather.feelsLike }}°C)</span></p>
        </div>
      </div>
      <span class="text-xs bg-theme-light-pink px-2.5 py-1 rounded-full text-theme-accent font-medium">{{ currentWeather.condition }}</span>
    </div>

    <!-- 時間軸行程清單 -->
    <div id="itinerary-list" class="relative space-y-2 pb-2">
      
      <!-- 全日貫穿的連續垂直線：位置在左側 48px 處 -->
      <div class="absolute left-[48px] top-3 bottom-3 w-0.5 bg-gradient-to-b from-theme-primary via-theme-secondary to-theme-primary rounded-full z-0"></div>

      <div v-for="(item, index) in filteredItinerary" :key="item.id" :data-id="item.id" class="relative flex items-start z-10">
        
        <!-- 左側時間與圓點區塊 -->
        <div class="w-[48px] flex-shrink-0 pt-1 flex flex-col items-end pr-3 relative">
          <span class="text-[10px] font-bold text-theme-dark leading-none block mb-1 text-right">{{ item.time || '--:--' }}</span>
          <div class="w-3 h-3 rounded-full bg-white border-2 border-theme-primary shadow-sm absolute right-[-6px] top-1 z-10"></div>
        </div>

        <!-- 右側：行程內容區域 -->
        <div class="flex-1 pl-2">
          <!-- 航班卡片 -->
          <div v-if="item.category === '航班'" class="bg-white border border-[#EBF0F3] rounded-2xl p-3 shadow-sm relative cursor-pointer text-theme-dark" @click="openEditModal('itinerary', item)">
            <div class="flex justify-between items-center text-xs border-b border-[#EBF0F3] pb-1.5 mb-1.5">
              <span class="text-gray-400 font-medium">{{ item.dateStr || '2026' }}</span>
              <span class="text-theme-primary font-bold">{{ item.fromCity }} ➔ {{ item.toCity }}</span>
              <span class="text-theme-accent font-bold bg-theme-light-pink px-2 py-0.5 rounded-md">{{ item.flightNo }}</span>
            </div>

            <div class="flex justify-between items-center my-1">
              <div>
                <p class="text-xs font-bold text-theme-primary">{{ item.depCode }}</p>
                <p class="text-xl font-bold text-theme-dark leading-tight">{{ item.depTime }}</p>
                <p class="text-[10px] text-gray-400 font-medium">{{ item.depTerminal }}</p>
              </div>

              <div class="flex-1 px-3 flex flex-col items-center">
                <span class="text-[10px] text-gray-400 font-medium mb-0.5">{{ item.duration || '4h 25m' }}</span>
                <div class="w-full flex items-center relative">
                  <div class="h-[1.5px] bg-[#EBF0F3] w-full rounded-full"></div>
                  <i data-lucide="plane" class="w-3.5 h-3.5 text-theme-primary absolute left-1/2 -translate-x-1/2 bg-white px-0.5 transform rotate-90 block"></i>
                  <div class="w-1.5 h-1.5 rounded-full bg-theme-secondary absolute right-0"></div>
                </div>
              </div>

              <div class="text-right">
                <p class="text-xs font-bold text-theme-primary">{{ item.arrCode }}</p>
                <p class="text-xl font-bold text-theme-dark leading-tight">{{ item.arrTime }}</p>
                <p class="text-[10px] text-gray-400 font-medium">{{ item.arrTerminal }}</p>
              </div>
            </div>

            <p class="text-[11px] text-theme-dark/70 mt-1.5 pt-1 border-t border-[#EBF0F3]" v-if="item.notes">備註：{{ item.notes }}</p>
          </div>

          <!-- 一般卡片 -->
          <div v-else class="bg-white rounded-2xl p-3 shadow-sm border border-[#EBF0F3] relative group cursor-pointer hover:border-theme-primary/30 transition-all" @click="openEditModal('itinerary', item)">
            <div class="flex justify-between items-start">
              <div>
                <span class="text-[10px] px-2 py-0.5 rounded-full font-medium mb-1 inline-block" :class="getCategoryBadgeClass(item.category)">
                  {{ item.category }}
                </span>
                <h3 class="font-bold text-theme-dark text-base">{{ item.title }}</h3>
              </div>
              <div class="flex items-center space-x-1">
                <!-- 排序拖曳把手 -->
                <span class="drag-handle p-1.5 text-gray-300 hover:text-theme-accent cursor-grab active:cursor-grabbing" title="按住拖曳排序">
                  <i data-lucide="grip-vertical" class="w-4 h-4 block"></i>
                </span>
                <a :href="getGoogleMapUrl(item)" target="_blank" @click.stop class="p-1.5 bg-theme-light-blue rounded-full text-theme-accent hover:bg-theme-accent hover:text-white transition-colors">
                  <i data-lucide="navigation" class="w-4 h-4 block"></i>
                </a>
              </div>
            </div>

            <div class="text-xs text-theme-muted space-y-0.5 mt-1">
              <p v-if="item.location" class="flex items-center gap-1 text-theme-accent font-medium"><i data-lucide="map-pin" class="w-3.5 h-3.5 block"></i> 地點: {{ item.location }}</p>
              <p v-if="item.ticket && item.ticket.trim() !== ''" class="flex items-center gap-1"><i data-lucide="ticket" class="w-3.5 h-3.5 block"></i> 門票: {{ item.ticket }}</p>
              <p v-if="item.notes" class="flex items-center gap-1 text-theme-dark/80"><i data-lucide="file-text" class="w-3.5 h-3.5 block"></i> {{ item.notes }}</p>
            </div>
          </div>

          <!-- 交通時間顯示 -->
          <div v-if="item.transportTime && item.transportTime.trim() !== ''" class="flex items-center justify-center space-x-1.5 my-1.5 text-xs text-theme-muted">
            <i :data-lucide="getTransportIcon(item.transportType)" class="w-3.5 h-3.5 text-theme-accent block"></i>
            <span class="font-medium text-theme-dark/70">{{ getTransportLabel(item.transportType) }} {{ item.transportTime }}</span>
          </div>
        </div>

      </div>
    </div>
  </div>

  <!-- 2. To-Do List & Packing List 頁面 -->
  <div v-show="currentTab === 'todolist'" class="px-4 pt-4 space-y-4">
    <div class="flex bg-white p-1 rounded-2xl shadow-sm text-xs border border-[#EBF0F3]">
      <button @click="todoTab = 'todo'" :class="{'bg-theme-primary text-white': todoTab === 'todo', 'text-theme-dark': todoTab !== 'todo'}" class="flex-1 py-2 rounded-xl transition-all font-medium">待辦事項 (To-Do)</button>
      <button @click="todoTab = 'packing'" :class="{'bg-theme-primary text-white': todoTab === 'packing', 'text-theme-dark': todoTab !== 'packing'}" class="flex-1 py-2 rounded-xl transition-all font-medium">行李打包 (Packing)</button>
    </div>

    <div class="space-y-3">
      <div v-for="item in activeTodoList" :key="item.id" 
           class="bg-white rounded-2xl p-3.5 shadow-sm flex items-center justify-between border border-[#EBF0F3]">
        <div class="flex items-center space-x-3 flex-1 cursor-pointer" @click="toggleTodoItem(item)">
          <div :class="{'bg-theme-primary border-theme-primary': item.done, 'border-gray-300': !item.done}" 
               class="w-5 h-5 rounded-full border-2 flex items-center justify-center transition-all flex-shrink-0">
            <i v-if="item.done" data-lucide="check" class="w-3.5 h-3.5 text-white block"></i>
          </div>
          <div>
            <span :class="{'line-through text-gray-300': item.done}" class="text-sm font-medium text-theme-dark block">{{ item.text }}</span>
            <div v-if="item.date || item.time" class="flex items-center gap-2 mt-0.5 text-[10px] text-theme-accent font-medium">
              <span v-if="item.date" class="flex items-center gap-0.5"><i data-lucide="calendar" class="w-3 h-3 inline block"></i> {{ item.date }}</span>
              <span v-if="item.time" class="flex items-center gap-0.5"><i data-lucide="clock" class="w-3 h-3 inline block"></i> {{ item.time }}</span>
            </div>
          </div>
        </div>
        <button @click.stop="openEditModal('todo', item)" class="p-1.5 text-gray-300 hover:text-theme-accent">
          <i data-lucide="pencil" class="w-4 h-4 block"></i>
        </button>
      </div>
    </div>
  </div>

  <!-- 3. 資訊頁面 -->
  <div v-show="currentTab === 'info'" class="px-4 pt-4 space-y-4">
    <div class="bg-white rounded-2xl p-4 shadow-sm border border-[#EBF0F3]">
      <h2 class="font-bold text-theme-dark mb-3 flex items-center gap-2"><i data-lucide="calculator" class="w-5 h-5 text-theme-accent block"></i> 匯率即時換算</h2>
      <div class="grid grid-cols-2 gap-3">
        <div>
          <label class="text-xs text-gray-400 mb-1 block">外幣金額</label>
          <input v-model.number="calcAmount" type="number" class="w-full bg-theme-light-blue rounded-xl p-2.5 text-sm focus:outline-none text-theme-dark" placeholder="金額">
        </div>
        <div>
          <label class="text-xs text-gray-400 mb-1 block">幣別</label>
          <select v-model="calcCurrency" class="w-full bg-theme-light-blue rounded-xl p-2.5 text-sm focus:outline-none text-theme-dark">
            <option value="JPY">日幣 (JPY)</option>
            <option value="SGD">新加坡幣 (SGD)</option>
            <option value="IDR">印尼盾 (IDR)</option>
          </select>
        </div>
      </div>
      <div class="mt-3 pt-3 border-t border-[#EBF0F3] text-right">
        <span class="text-xs text-gray-400">約合港幣：</span>
        <span class="text-xl font-bold text-theme-accent">HKD ${{ calculatedHKD }}</span>
      </div>
    </div>

    <div class="space-y-3">
      <h2 class="font-bold text-theme-dark flex items-center gap-2 px-1"><i data-lucide="plane" class="w-5 h-5 text-theme-accent block"></i> 航班資訊</h2>
      <div v-for="flight in flightCards" :key="flight.code" class="bg-white border border-[#EBF0F3] rounded-2xl p-3.5 shadow-sm text-theme-dark">
        <div class="flex justify-between items-center text-xs border-b border-[#EBF0F3] pb-2 mb-2">
          <span class="text-gray-400 font-medium">{{ flight.dateStr }}</span>
          <span class="text-theme-primary font-bold">{{ flight.fromCity }} ➔ {{ flight.toCity }}</span>
          <span class="text-theme-accent font-bold bg-theme-light-pink px-2 py-0.5 rounded-md">{{ flight.code }}</span>
        </div>

        <div class="flex justify-between items-center my-1">
          <div>
            <p class="text-xs font-bold text-theme-primary">{{ flight.depCode }}</p>
            <p class="text-xl font-bold text-theme-dark leading-tight">{{ flight.depTime }}</p>
            <p class="text-[10px] text-gray-400 font-medium">{{ flight.depTerminal }}</p>
          </div>

          <div class="flex-1 px-3 flex flex-col items-center">
            <span class="text-[10px] text-gray-400 font-medium mb-0.5">{{ flight.duration }}</span>
            <div class="w-full flex items-center relative">
              <div class="h-[1.5px] bg-[#EBF0F3] w-full rounded-full"></div>
              <i data-lucide="plane" class="w-3.5 h-3.5 text-theme-accent absolute left-1/2 -translate-x-1/2 bg-white px-0.5 transform rotate-90 block"></i>
              <div class="w-1.5 h-1.5 rounded-full bg-theme-secondary absolute right-0"></div>
            </div>
          </div>

          <div class="text-right">
            <p class="text-xs font-bold text-theme-primary">{{ flight.arrCode }}</p>
            <p class="text-xl font-bold text-theme-dark leading-tight">{{ flight.arrTime }}</p>
            <p class="text-[10px] text-gray-400 font-medium">{{ flight.arrTerminal }}</p>
          </div>
        </div>
      </div>
    </div>

    <div class="space-y-3">
      <h2 class="font-bold text-theme-dark flex items-center gap-2 px-1"><i data-lucide="hotel" class="w-5 h-5 text-theme-accent block"></i> 住宿資訊</h2>
      <div v-for="hotel in hotels" :key="hotel.name" class="bg-white border border-[#EBF0F3] rounded-2xl p-3.5 shadow-sm text-theme-dark">
        <div class="flex justify-between items-center border-b border-[#EBF0F3] pb-2 mb-2">
          <span class="font-bold text-sm text-theme-dark truncate max-w-[200px]">{{ hotel.name }}</span>
          <a :href="'https://www.google.com/maps/search/?api=1&query=' + encodeURIComponent(hotel.name)" target="_blank" class="text-xs text-theme-accent flex items-center gap-0.5 font-medium hover:underline">
            導航 <i data-lucide="external-link" class="w-3 h-3 block"></i>
          </a>
        </div>

        <div class="flex justify-between items-center my-1">
          <div>
            <p class="text-xs font-bold text-theme-accent">CHECK-IN</p>
            <p class="text-xl font-bold text-theme-dark leading-tight">{{ hotel.ci }}</p>
            <p class="text-[10px] text-gray-400 font-medium">{{ hotel.date.split('-')[0] }}</p>
          </div>

          <div class="flex-1 px-3 flex flex-col items-center">
            <span class="text-[10px] text-gray-400 font-medium mb-0.5">{{ hotel.nights }}</span>
            <div class="w-full flex items-center relative">
              <div class="h-[1.5px] bg-[#EBF0F3] w-full rounded-full"></div>
              <i data-lucide="bed" class="w-3.5 h-3.5 text-theme-secondary absolute left-1/2 -translate-x-1/2 bg-white px-0.5 block"></i>
              <div class="w-1.5 h-1.5 rounded-full bg-theme-primary absolute right-0"></div>
            </div>
          </div>

          <div class="text-right">
            <p class="text-xs font-bold text-theme-accent">CHECK-OUT</p>
            <p class="text-xl font-bold text-theme-dark leading-tight">{{ hotel.co }}</p>
            <p class="text-[10px] text-gray-400 font-medium">{{ hotel.date.split('-')[1] }}</p>
          </div>
        </div>

        <div class="text-[10px] text-gray-400 mt-2 pt-2 border-t border-[#EBF0F3] space-y-1">
          <div class="flex justify-between">
            <span>房型: {{ hotel.room }}</span>
            <span class="font-medium text-theme-dark/70">{{ hotel.date }}</span>
          </div>
          <p v-if="hotel.address" class="flex items-center gap-1 text-theme-dark/80"><i data-lucide="map-pin" class="w-3 h-3 text-theme-accent block"></i> {{ hotel.address }}</p>
          <p v-if="hotel.phone" class="flex items-center gap-1 text-theme-dark/80"><i data-lucide="phone" class="w-3 h-3 text-theme-accent block"></i> <a :href="'tel:' + hotel.phone" class="hover:underline text-theme-accent font-medium">{{ hotel.phone }}</a></p>
        </div>
      </div>
    </div>
  </div>

  <!-- 4. 購物清單頁面 -->
  <div v-show="currentTab === 'shopping'" class="px-4 pt-4">
    <div class="flex bg-white p-1 rounded-2xl mb-4 shadow-sm text-xs border border-[#EBF0F3]">
      <button v-for="region in ['日本', '新加坡', '峇里島']" :key="region" 
              @click="selectedRegion = region"
              :class="{'bg-theme-primary text-white': selectedRegion === region, 'text-theme-dark': selectedRegion !== region}"
              class="flex-1 py-2 rounded-xl text-center transition-all font-medium">
        {{ region }}
      </button>
    </div>

    <div class="space-y-3">
      <div v-for="item in filteredShoppingList" :key="item.id" 
           class="bg-white rounded-2xl p-3 shadow-sm flex items-center justify-between border border-[#EBF0F3]">
        <div class="flex items-center space-x-3 flex-1 cursor-pointer" @click="toggleShopItem(item)">
          <div :class="{'bg-theme-primary border-theme-primary': item.done, 'border-gray-300': !item.done}" 
               class="w-5 h-5 rounded-full border-2 flex items-center justify-center transition-all">
            <i v-if="item.done" data-lucide="check" class="w-3.5 h-3.5 text-white block"></i>
          </div>
          <span :class="{'line-through text-gray-300': item.done}" class="text-sm font-medium text-theme-dark">{{ item.name }}</span>
        </div>
        <button @click.stop="openEditModal('shopping', item)" class="p-2 text-gray-300 hover:text-theme-accent">
          <i data-lucide="pencil" class="w-4 h-4 block"></i>
        </button>
      </div>
    </div>
  </div>

  <!-- 5. 花費頁面 -->
  <div v-show="currentTab === 'expenses'" class="px-4 pt-4 space-y-4">
    <div class="bg-gradient-to-r from-theme-primary to-theme-secondary text-white rounded-2xl p-4 shadow-md">
      <div class="flex justify-between items-center border-b border-white/25 pb-3 mb-3">
        <div>
          <p class="text-[10px] opacity-80 uppercase tracking-wider">總花費 (HKD)</p>
          <p class="text-2xl font-bold">HKD ${{ totalExpenseHKD }}</p>
        </div>
        <div class="text-right">
          <p class="text-[10px] opacity-80 uppercase tracking-wider">結算狀態</p>
          <p class="text-sm font-bold bg-white/20 px-2.5 py-1 rounded-full inline-block mt-0.5">{{ settlementStatus }}</p>
        </div>
      </div>
