        { id: '107', date: '2026-09-21', category: '住宿', title: '出發: The Apurva Kempinski Bali', location: 'The Apurva Kempinski Bali', time: '10:00', ticket: '', notes: '峇里島自由探索', transportType: 'car', transportTime: '20 分鐘' },
        { id: '108', date: '2026-09-21', category: '住宿', title: '返回 The Apurva Kempinski 休息', location: 'The Apurva Kempinski Bali', time: '21:30', ticket: '', notes: '', transportType: 'walk', transportTime: '' },
        
        { id: '109', date: '2026-09-22', category: '住宿', title: 'Check-out: The Apurva Kempinski Bali', location: 'The Apurva Kempinski Bali', time: '12:00', ticket: '', notes: '退房前往機場', transportType: 'car', transportTime: '30 分鐘' },
        { 
          id: '110', date: '2026-09-22', category: '航班', title: '峇里島飛香港', 
          dateStr: 'Tue 22 Sep 2026', flightNo: 'CX784', fromCity: 'Bali', toCity: 'Hong Kong', 
          depCode: 'DPS', depTime: '16:15', depTerminal: 'International', 
          arrCode: 'HKG', arrTime: '21:25', arrTerminal: 'Terminal 1', 
          duration: '5h 10m', notes: '返抵香港', transportType: 'walk', transportTime: '' 
        }
      ];

      // 讀取本地端儲存，若無則使用預設行程
      const loadSavedItinerary = () => {
        const saved = localStorage.getItem('trip_itinerary_2026');
        if (saved) {
          try { return JSON.parse(saved); } catch (e) { }
        }
        return defaultItinerary;
      };

      const itineraryList = ref(loadSavedItinerary());

      // 儲存至 LocalStorage 的輔助函式
      const saveItineraryStorage = () => {
        localStorage.setItem('trip_itinerary_2026', JSON.stringify(itineraryList.value));
      };

      const filteredItinerary = computed(() => {
        return itineraryList.value.filter(item => item.date === selectedDate.value);
      });

      const shoppingList = ref([
        { id: '1', region: '日本', name: '資生堂防曬乳', done: false },
        { id: '2', region: '新加坡', name: '班蘭蛋糕', done: true },
        { id: '3', region: '峇里島', name: '手工草編包', done: false }
      ]);

      const filteredShoppingList = computed(() => {
        return shoppingList.value.filter(item => item.region === selectedRegion.value);
      });

      const expenses = ref([
        { id: '1', category: '飲食', title: '銀座八五拉麵', date: '2026-09-15', amount: 4000, currency: 'JPY', hkdAmount: '208.0', payer: 'bb', split: 'both' },
        { id: '2', category: '購物', title: '松本清藥妝', date: '2026-09-15', amount: 12000, currency: 'JPY', hkdAmount: '624.0', payer: 'cc', split: 'both' },
        { id: '3', category: '門票', title: 'Pixar 展覽門票', date: '2026-09-15', amount: 4000, currency: 'JPY', hkdAmount: '208.0', payer: 'bb', split: 'both' }
      ]);

      const expenseFilter = ref('all');

      const filteredExpenses = computed(() => {
        if (expenseFilter.value === 'bb') return expenses.value.filter(e => e.payer === 'bb');
        if (expenseFilter.value === 'cc') return expenses.value.filter(e => e.payer === 'cc');
        return expenses.value;
      });

      const totalExpenseHKD = computed(() => {
        return expenses.value.reduce((sum, item) => sum + Number(item.hkdAmount || 0), 0).toFixed(1);
      });

      const bbTotalPaid = computed(() => {
        return expenses.value.filter(e => e.payer === 'bb').reduce((sum, item) => sum + Number(item.hkdAmount || 0), 0).toFixed(1);
      });

      const ccTotalPaid = computed(() => {
        return expenses.value.filter(e => e.payer === 'cc').reduce((sum, item) => sum + Number(item.hkdAmount || 0), 0).toFixed(1);
      });

      const settlementStatus = computed(() => {
        let ccOwesBb = 0;
        expenses.value.forEach(exp => {
          const hkd = Number(exp.hkdAmount) || 0;
          if (exp.payer === 'bb') {
            if (exp.split === 'both') ccOwesBb += hkd / 2;
            else if (exp.split === 'cc') ccOwesBb += hkd;
          } else if (exp.payer === 'cc') {
            if (exp.split === 'both') ccOwesBb -= hkd / 2;
            else if (exp.split === 'bb') ccOwesBb -= hkd;
          }
        });

        if (Math.abs(ccOwesBb) < 0.1) return '互不相欠 👍';
        if (ccOwesBb > 0) return `cc 需給 bb HKD $${ccOwesBb.toFixed(1)}`;
        return `bb 需給 cc HKD $${Math.abs(ccOwesBb).toFixed(1)}`;
      });

      const formData = ref({});

      const switchTab = (tab) => {
        currentTab.value = tab;
        renderIcons();
      };

      const openAddModal = (type) => {
        modalType.value = type;
        isEditing.value = false;

        if (type === 'itinerary') {
          formData.value = { 
            date: selectedDate.value, category: '景點', title: '', location: '', ticket: '', time: '10:00', transportType: 'walk', transportTime: '',
            dateStr: '', flightNo: '', fromCity: '', toCity: '', depCode: '', depTime: '', depTerminal: '', arrCode: '', arrTime: '', arrTerminal: '', duration: ''
          };
        } else if (type === 'todo') {
          formData.value = { type: todoTab.value, text: '', date: '', time: '' };
        } else if (type === 'expense') {
          formData.value = {
            category: '飲食', title: '', date: selectedDate.value, amount: 0, currency: 'JPY', payer: 'bb', split: 'both'
          };
        } else if (type === 'shopping') {
          formData.value = { region: selectedRegion.value, name: '' };
        }

        showModal.value = true;
        renderIcons();
      };

      const openEditModal = (type, item) => {
        modalType.value = type;
        isEditing.value = true;
        formData.value = JSON.parse(JSON.stringify(item));
        showModal.value = true;
        renderIcons();
      };

      const closeModal = () => { showModal.value = false; };

      // 輔助函式：將時間字串轉換為分數（方便比較大小）
      const parseTimeToMinutes = (timeStr) => {
        if (!timeStr || typeof timeStr !== 'string') return 9999;
        const parts = timeStr.trim().split(':');
        if (parts.length < 2) return 9999;
        const h = parseInt(parts[0], 10);
        const m = parseInt(parts[1], 10);
        if (isNaN(h) || isNaN(m)) return 9999;
        return h * 60 + m;
      };

      const saveFormData = () => {
        if (modalType.value === 'itinerary') {
          if (isEditing.value) {
            const idx = itineraryList.value.findIndex(i => i.id === formData.value.id);
            if (idx !== -1) itineraryList.value[idx] = { ...formData.value };
          } else {
            const newItem = { ...formData.value, id: Date.now().toString() };
            itineraryList.value.push(newItem);
          }

          // 根據該日所有行程的時間進行自動排序
          const targetDate = formData.value.date || selectedDate.value;
          const otherDays = itineraryList.value.filter(i => i.date !== targetDate);
          const currentDayItems = itineraryList.value.filter(i => i.date === targetDate);

          currentDayItems.sort((a, b) => {
            const timeA = a.category === '航班' ? (a.depTime || '00:00') : (a.time || '00:00');
            const timeB = b.category === '航班' ? (b.depTime || '00:00') : (b.time || '00:00');
            return parseTimeToMinutes(timeA) - parseTimeToMinutes(timeB);
          });

          itineraryList.value = [...otherDays, ...currentDayItems].sort((a, b) => {
            if (a.date !== b.date) return a.date.localeCompare(b.date);
            const timeA = a.category === '航班' ? (a.depTime || '00:00') : (a.time || '00:00');
            const timeB = b.category === '航班' ? (b.depTime || '00:00') : (b.time || '00:00');
            return parseTimeToMinutes(timeA) - parseTimeToMinutes(timeB);
          });

          saveItineraryStorage();
        } else if (modalType.value === 'todo') {
          if (isEditing.value) {
            const idx = todoList.value.findIndex(t => t.id === formData.value.id);
            if (idx !== -1) todoList.value[idx] = { ...formData.value };
          } else {
            todoList.value.push({ ...formData.value, id: Date.now().toString(), done: false });
          }
        } else if (modalType.value === 'expense') {
          const rate = rates[formData.value.currency] || 1;
          formData.value.hkdAmount = ((formData.value.amount || 0) * rate).toFixed(1);

          if (isEditing.value) {
            const idx = expenses.value.findIndex(e => e.id === formData.value.id);
            if (idx !== -1) expenses.value[idx] = { ...formData.value };
          } else {
            expenses.value.push({ ...formData.value, id: Date.now().toString() });
          }
        } else if (modalType.value === 'shopping') {
          if (isEditing.value) {
            const idx = shoppingList.value.findIndex(s => s.id === formData.value.id);
            if (idx !== -1) shoppingList.value[idx] = { ...formData.value };
          } else {
            shoppingList.value.push({ ...formData.value, id: Date.now().toString(), done: false });
          }
        }

        closeModal();
        renderIcons();
      };

      const confirmDelete = () => {
        if (confirm('確定要刪除嗎？')) {
          if (modalType.value === 'itinerary') {
            itineraryList.value = itineraryList.value.filter(i => i.id !== formData.value.id);
            saveItineraryStorage();
          } else if (modalType.value === 'todo') {
            todoList.value = todoList.value.filter(t => t.id !== formData.value.id);
          } else if (modalType.value === 'expense') {
            expenses.value = expenses.value.filter(e => e.id !== formData.value.id);
          } else if (modalType.value === 'shopping') {
            shoppingList.value = shoppingList.value.filter(s => s.id !== formData.value.id);
          }
          closeModal();
          renderIcons();
        }
      };

      const toggleTodoItem = (item) => { item.done = !item.done; };
      const toggleShopItem = (item) => { item.done = !item.done; };

      const getGoogleMapUrl = (item) => {
        const targetSearch = item.location && item.location.trim() !== '' ? item.location : item.title;
        return `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(targetSearch)}`;
      };

      const getCategoryBadgeClass = (cat) => {
        const classes = {
          '景點': 'bg-theme-light-blue text-theme-accent font-bold',
          '美食': 'bg-theme-light-pink text-theme-primary font-bold',
          '住宿': 'bg-theme-light-blue text-theme-dark font-bold',
          '婚禮': 'bg-theme-light-pink text-theme-primary font-bold',
          '購物': 'bg-theme-light-blue text-theme-accent font-bold'
        };
        return classes[cat] || 'bg-gray-100 text-gray-600';
      };

      const getTransportIcon = (type) => {
        if (type === 'walk') return 'footprints';
        if (type === 'bus') return 'bus';
        if (type === 'subway') return 'train';
        if (type === 'car') return 'car';
        return 'bus';
      };

      const getTransportLabel = (type) => {
        if (type === 'walk') return '步行';
        if (type === 'bus') return '巴士';
        if (type === 'subway') return '地鐵';
        if (type === 'car') return '車程';
        return '';
      };

      const getSplitLabel = (split) => {
        if (split === 'both') return '平分 (AA)';
        if (split === 'bb') return 'bb 獨負';
        if (split === 'cc') return 'cc 獨負';
        return '';
      };

      const renderIcons = () => {
        nextTick(() => {
          if (window.lucide) {
            window.lucide.createIcons();
          }
        });
      };

      // 初始化 Sortable 拖曳排序並自動儲存至 LocalStorage
      const initSortable = () => {
        nextTick(() => {
          const el = document.getElementById('itinerary-list');
          if (el && window.Sortable && !el.__sortableInstance) {
            el.__sortableInstance = Sortable.create(el, { 
              animation: 150,
              handle: '.drag-handle',
              onEnd: (evt) => {
                const movedItem = filteredItinerary.value[evt.oldIndex];
                if (!movedItem) return;
                
                // 從原始陣列移除被拖曳的項目
                const originalIndex = itineraryList.value.findIndex(i => i.id === movedItem.id);
                if (originalIndex !== -1) {
                  itineraryList.value.splice(originalIndex, 1);
                }
                
                // 計算新的當日列表順序
                const newFilteredList = [...filteredItinerary.value];
                newFilteredList.splice(evt.newIndex, 0, movedItem);
                
                // 重新組合完整 itineraryList
                const otherDaysItems = itineraryList.value.filter(i => i.date !== selectedDate.value);
                itineraryList.value = [
                  ...otherDaysItems.filter(i => i.date < selectedDate.value),
                  ...newFilteredList,
                  ...otherDaysItems.filter(i => i.date > selectedDate.value)
                ];

                // 自動儲存至 LocalStorage
                saveItineraryStorage();
                renderIcons();
              }
            });
          }
        });
      };

      onMounted(() => {
        renderIcons();
        initSortable();
      });

      watch(selectedDate, () => {
        initSortable();
        renderIcons();
      });

      return {
        currentTab, selectedDate, selectedRegion, todoTab, dates, flightCards, hotels,
        currentCity, currentWeather, filteredItinerary, filteredShoppingList, todoList, activeTodoList,
        expenses, totalExpenseHKD, bbTotalPaid, ccTotalPaid, settlementStatus,
        expenseFilter, filteredExpenses, calcAmount, calcCurrency, calculatedHKD,
        showModal, isEditing, modalType, formData, switchTab,
        openAddModal, openEditModal, closeModal, saveFormData, confirmDelete,
        toggleTodoItem, toggleShopItem, getGoogleMapUrl, getCategoryBadgeClass, getTransportIcon, getTransportLabel, getSplitLabel, renderIcons
      };
    }
  }).mount('#app');
</script>

